# Hugging Face API Token (needed to authenticate or cache models)
# Get one here: https://huggingface.co/settings/tokens
HF_API_TOKEN=your_hf_token_here

# DeepSeek API Key (used for translate/summary features in the Video tab)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# HTR Qwen LoRA Checkpoint Path (absolute path to checkpoint-200)
# Example (Windows): j:\HTR_MAGHRIBI_DATASET\qwen2_5_vl_ocr_pipeline\outputs\htr_cot_qwen3_5_v3\checkpoint-200
# Example (Linux VPS): /home/user/qwen2_5_vl_ocr_pipeline/outputs/htr_cot_qwen3_5_v3/checkpoint-200
HTR_CHECKPOINT_PATH=j:\HTR_MAGHRIBI_DATASET\qwen2_5_vl_ocr_pipeline\outputs\htr_cot_qwen3_5_v3\checkpoint-200

# Next.js API Proxy target for Python HTR API
# Defaults to http://127.0.0.1:8001/predict_batch
PYTHON_HTR_API_URL=http://127.0.0.1:8001/predict_batch

# Video Transcription Engine (NVIDIA NeMo Conformer)
# Path to Al-Kutub-Automator repository root and the Arabic FastConformer .nemo model
# Leave blank to fallback to sibling directory layout: ../Al-Kutub-Automator
# Example (Windows): j:\UnivHm_NextJS\Al-Kutub-Automator
# Example (Linux VPS): /home/user/Al-Kutub-Automator
AL_KUTUB_DIR=
NEMO_MODEL_PATH=
